# IP Platform — access codes (comma-separated, case-insensitive)
IP_PLATFORM_CODES=REWEAVE-IP,PARTNER-DEMO

# Secret for session cookies (use a long random string in production)
IP_VAULT_SECRET=replace-with-a-long-random-secret

# Contact form — optional Resend email (https://resend.com)
# Without RESEND_API_KEY, submissions are saved to private/contact-submissions/
CONTACT_TO_EMAIL=info@transformingtextiles.com
NEXT_PUBLIC_CONTACT_EMAIL=info@transformingtextiles.com
CONTACT_FROM_EMAIL=RE:WEAVE Website <onboarding@resend.dev>
RESEND_API_KEY=
